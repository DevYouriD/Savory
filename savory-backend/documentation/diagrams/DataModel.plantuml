@startuml
entity "Recipe" as Recipe {
  +String id
  +String title
  +String description
  +String instructions
  +String imageUrl
  +int preparationTime
  +int cookingTime
  +int servings
  +Category category
  +String author
  +String createdAt
  +String updatedAt
  +List<Ingredient> ingredients
}

entity "Ingredient" as Ingredient {
  +String name
  +String unit
  +Float quantity
}

Recipe o-- "0..*" Ingredient

@enduml